# ---------------------------------------------------------------------------
# Quote My Tattoo - environment variables
# Copy this file to ".env.local" and fill in the values. See SUPABASE_SETUP.md
# for click-by-click instructions on where to find each value.
# ---------------------------------------------------------------------------

# Supabase - Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase service role key - Project Settings → API (KEEP SECRET, server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend - https://resend.com/api-keys (used for lead/quote/message emails)
RESEND_API_KEY=re_your_api_key
# The "from" address emails are sent as (must be a verified Resend domain)
EMAIL_FROM="Quote My Tattoo <hello@quotemytattoo.com>"

# The site's public base URL (used in emails and canonical/sitemap URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
